        },
        "active": {
          "$description": "For the [data-active] state",
          "$type": "object",
          "color": {
            "$value": "{color.primary}"
          },
          "border-color": {
            "$value": "{color.primary}"
          }
        }
      },
      "panel": {
        "$description": "The content panel",
        "$type": "object",
        "padding": {
          "$value": "{space.lg}"
        }
      }
    },
    "dropdown": {
      "$description": "Tokens for the Dropdown menu (inherits from Select)",
      "$type": "object",
      "menu": {
        "$description": "The floating panel",
        "$value": "{select.menu}"
      },
      "item": {
        "$description": "An item within the menu",
        "$value": "{select.option}"
      }
    },
    "breadcrumbs": {
      "$description": "Tokens for the Breadcrumbs component",
      "$type": "object",
      "font-size": {
        "$value": "{font-size.sm}"
      },
      "font-family": {
        "$value": "{font.system}"
      },
      "gap": {
        "$value": "{space.xs}"
      },
      "item": {
        "$type": "object",
        "color": {
          "$value": "{color.gray}"
        }
      },
      "item-current": {
        "$description": "For the final item (current page)",
        "$type": "object",
        "color": {
          "$value": "{color.darker-gray}"
        },
        "font-weight": {
          "$value": "{font.weight.bold}"
        }
      },
      "separator": {
        "$type": "object",
        "color": {
          "$value": "{color.gray}"
        }
      }
    },
    "pagination": {
      "$description": "Tokens for the Pagination component",
      "$type": "object",
      "font-size": {
        "$value": "{font-size.sm}"
      },
      "color": {
        "$value": "{color.dark-gray}"
      },
      "bg": {
        "$value": "transparent"
      },
      "border-color": {
        "$value": "{color.light-gray}"
      },
      "color-hover": {
        "$value": "{color.primary}"
      },
      "bg-hover": {
        "$value": "transparent"
      },
      "border-hover": {
        "$value": "{color.primary}"
      },
      "color-active": {
        "$value": "{color.primary}"
      },
      "bg-active": {
        "$value": "transparent"
      },
      "border-active": {
        "$value": "{color.primary}"
      },
      "color-disabled": {
        "$value": "{color.gray}"
      },
      "bg-disabled": {
        "$value": "{color.light-gray}"
      },
      "border-disabled": {
        "$value": "{color.light-gray}"
      },
      "size": {
        "$value": "{space.xl}"
      },
      "size-small": {
        "$value": "{space.lg}"
      },
      "radius": {
        "$value": "{border-radius.base}"
      }
    },
    "link": {
      "$description": "Tokens for the Link component (for [data-link])",
      "$type": "object",
      "color": {
        "$value": "{color.primary}"
      },
      "text-decoration": {
        "$value": "underline"
      },
      "hover": {
        "$type": "object",
        "color": {
          "$value": "{color.accent}"
        }
      },
      "focus": {
        "$type": "object",
        "outline-color": {
          "$value": "{color.primary}"
        },
        "outline-width": {
          "$value": "2px"
        },
        "outline-offset": {
          "$value": "2px"
        }
      }
    }
  },
  "themes": {
    "light": {
      "$description": "Light theme (Default)",
      "color": {
        "text": {
          "default": { "$value": "{color.secondary.900}" },
          "muted": { "$value": "{color.secondary.500}" },
          "inverse": { "$value": "{color.white}" }
        },
        "bg": {
          "canvas": { "$value": "{color.secondary.50}" },
          "surface": { "$value": "{color.white}" },
          "surface-hover": { "$value": "{color.secondary.100}" }
        },
        "border": {
          "default": { "$value": "{color.secondary.200}" },
          "active": { "$value": "{color.primary.500}" }
        },
        "primary": {
          "default": { "$value": "{color.primary.600}" },
          "fg": { "$value": "{color.white}" },
          "hover": { "$value": "{color.primary.700}" }
        }
      }
    },
    "dark": {
      "$description": "Dark theme",
      "color": {
        "text": {
          "default": { "$value": "{color.white}" },
          "muted": { "$value": "{color.secondary.400}" },
          "inverse": { "$value": "{color.secondary.900}" }
        },
        "bg": {
          "canvas": { "$value": "{color.secondary.950}" },
          "surface": { "$value": "{color.secondary.900}" },
          "surface-hover": { "$value": "{color.secondary.800}" }
        },
        "border": {
          "default": { "$value": "{color.secondary.800}" },
          "active": { "$value": "{color.primary.400}" }
        },
        "primary": {
          "default": { "$value": "{color.primary.500}" },
          "fg": { "$value": "{color.white}" },
          "hover": { "$value": "{color.primary.400}" }
        }
      }
    },
    "radar": {
      "$description": "Daredevil Accessibility Theme (High Contrast)",
      "color": {
        "text": {
          "default": { "$value": "{color.white}" },
          "muted": { "$value": "{color.crimson.100}" },
          "inverse": { "$value": "{color.black}" }
        },
        "bg": {
          "canvas": { "$value": "{color.crimson.950}" },
          "surface": { "$value": "{color.black}" },
          "surface-hover": { "$value": "{color.crimson.900}" }
        },
        "border": {
          "default": { "$value": "{color.crimson.700}" },
          "active": { "$value": "{color.crimson.400}" }
        },
        "primary": {
          "default": { "$value": "{color.crimson.500}" },
          "fg": { "$value": "{color.white}" },
          "hover": { "$value": "{color.crimson.400}" }
        }
      }
    }
  }
}
