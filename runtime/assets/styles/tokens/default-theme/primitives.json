      "$value": "'Inter', system-ui, -apple-system, sans-serif"
    },
    "system": {
      "$value": "system-ui, sans-serif"
    }
  },
  "font-size": {
    "$description": "Fluid font size scale (Major Third 1.25x)",
    "$type": "dimension",
    "base": {
      "$value": "clamp(1rem, 0.98rem + 0.1vw, 1.1rem)"
    },
    "md": {
      "$value": "{font-size.base}"
    },
    "xs": {
      "$value": "clamp(0.64rem, 0.62rem + 0.05vw, 0.7rem)"
    },
    "sm": {
      "$value": "clamp(0.8rem, 0.78rem + 0.1vw, 0.88rem)"
    },
    "lg": {
      "$value": "clamp(1.25rem, 1.22rem + 0.15vw, 1.375rem)"
    },
    "xl": {
      "$value": "clamp(1.56rem, 1.52rem + 0.2vw, 1.72rem)"
    },
    "xxl": {
      "$value": "clamp(1.95rem, 1.91rem + 0.25vw, 2.15rem)"
    },
    "ul": {
      "$value": "clamp(2.44rem, 2.39rem + 0.3vw, 2.69rem)"
    }
  },
