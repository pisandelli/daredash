{
  "$description": "Tokens for the individual toast pop-up",
  "$type": "object",
  "padding": {
    "$value": "{space.md}"
  },
  "border-radius": {
    "$value": "{space.xs}"
  },
  "font-family": {
    "$value": "{font.system}"
  },
  "box-shadow": {
    "$description": "Reuses the card shadow",
    "$value": "{card.box-shadow}"
  },
  "close-size": {
    "$description": "Size of the close icon",
    "$value": "{font-size.lg}"
  },
  "icon-size": {
    "$description": "Size of the leading semantic icon",
    "$value": "1.5rem"
  },
  "cluster-gap": {
    "$description": "Internal gap between message and close button",
    "$value": "{space.xs}"
  },
  "background": {
    "$value": "{color.white}"
  },
  "color": {
    "$value": "{color.text.default}"
  },
  "border-color": {
    "$value": "{color.border.default}"
  },
  "icon-color": {
    "$value": "{color.info}"
  },
  "success": {
    "icon-color": {
      "$value": "{color.success}"
    }
  },
  "warning": {
    "icon-color": {
      "$value": "{color.warning}"
    }
  },
  "danger": {
    "icon-color": {
      "$value": "{color.danger}"
    }
  },
  "error": {
    "icon-color": {
      "$value": "{color.error}"
    }
  },
  "info": {
    "icon-color": {
      "$value": "{color.info}"
    }
  },
  "close-color": {
    "$value": "{color.darker-gray}"
  },
  "close-hover-color": {
    "$value": "{color.danger.600}"
  },
  "close-hover-bg": {
    "$value": "{color.danger.50}"
  },
  "solid": {
    "primary": {
      "background": {
        "$value": "{color.primary}"
      },
      "color": {
        "$value": "contrast-color({toast.solid.primary.background})"
      },
      "icon-color": {
        "$value": "{toast.solid.primary.color}"
      },
      "close-hover-bg": {
        "$value": "rgba(255, 255, 255, 0.2)"
      }
    },
    "success": {
      "background": {
        "$value": "{color.success}"
      },
      "color": {
        "$value": "contrast-color({toast.solid.success.background})"
      },
      "icon-color": {
        "$value": "{toast.solid.success.color}"
      },
      "close-hover-bg": {
        "$value": "rgba(255, 255, 255, 0.2)"
      }
    },
    "warning": {
      "background": {
        "$value": "{color.warning}"
      },
      "color": {
        "$value": "contrast-color({toast.solid.warning.background})"
      },
      "icon-color": {
        "$value": "{toast.solid.warning.color}"
      },
      "close-hover-bg": {
        "$value": "rgba(0, 0, 0, 0.1)"
      }
    },
    "danger": {
      "background": {
        "$value": "{color.danger}"
      },
      "color": {
        "$value": "contrast-color({toast.solid.danger.background})"
      },
      "icon-color": {
        "$value": "{toast.solid.danger.color}"
      },
      "close-hover-bg": {
        "$value": "rgba(255, 255, 255, 0.2)"
      }
    },
    "error": {
      "background": {
        "$value": "{color.error}"
      },
      "color": {
        "$value": "contrast-color({toast.solid.error.background})"
      },
      "icon-color": {
        "$value": "{toast.solid.error.color}"
      },
      "close-hover-bg": {
        "$value": "rgba(255, 255, 255, 0.2)"
      }
    },
    "info": {
      "background": {
        "$value": "{color.info}"
      },
      "color": {
        "$value": "contrast-color({toast.solid.info.background})"
      },
      "icon-color": {
        "$value": "{toast.solid.info.color}"
      },
      "close-hover-bg": {
        "$value": "rgba(255, 255, 255, 0.2)"
      }
    }
  }
}
