{
  "$description": "Tokens for the Textarea component, inherits from Input",
  "$type": "object",
  "background-color": {
    "$value": "{input.background-color}"
  },
  "border-radius": {
    "$value": "{input.border-radius}"
  },
  "border-width": {
    "$value": "{input.border-width}"
  },
  "border-style": {
    "$value": "{input.border-style}"
  },
  "border-color": {
    "$value": "{input.border-color}"
  },
  "color": {
    "$value": "{input.color}"
  },
  "font-family": {
    "$value": "{input.font-family}"
  },
  "font-size": {
    "$value": "{input.font-size}"
  },
  "font-weight": {
    "$value": "{input.font-weight}"
  },
  "padding": {
    "inline": {
      "start": {
        "$value": "{input.padding.inline.start}"
      },
      "end": {
        "$value": "{input.padding.inline.end}"
      }
    },
    "block": {
      "start": {
        "$value": "{input.padding.block.start}"
      },
      "end": {
        "$value": "{input.padding.block.end}"
      }
    }
  },
  "label": {
    "$type": "object",
    "color": {
      "$value": "{input.label.color}"
    },
    "font-size": {
      "$value": "{input.label.font-size}"
    },
    "font-weight": {
      "$value": "{input.label.font-weight}"
    }
  },
  "focus": {
    "$type": "object",
    "border-color": {
      "$value": "{input.focus.border-color}"
    },
    "box-shadow": {
      "$value": "{input.focus.box-shadow}"
    },
    "outline": {
      "$value": "{input.focus.outline}"
    }
  },
  "disabled": {
    "$type": "object",
    "background-color": {
      "$value": "{input.disabled.background-color}"
    },
    "color": {
      "$value": "{input.disabled.color}"
    },
    "cursor": {
      "$value": "{input.disabled.cursor}"
    },
    "border-color": {
      "$value": "{color.secondary-200}"
    }
  },
  "error-state": {
    "$type": "object",
    "border-color": {
      "$value": "{input.error-state.border-color}"
    }
  },
  "success-state": {
    "$type": "object",
    "border-color": {
      "$value": "{color.success}"
    }
  },
  "warning-state": {
    "$type": "object",
    "border-color": {
      "$value": "{color.warning}"
    }
  },
  "error-label": {
    "$type": "object",
    "font-family": {
      "$value": "{input.error-label.font-family}"
    },
    "font-weight": {
      "$value": "{input.error-label.font-weight}"
    },
    "color": {
      "$value": "{input.error-label.color}"
    },
    "font-size": {
      "$value": "{input.error-label.font-size}"
    }
  },
  "min-height": {
    "$value": "10rem"
  },
  "resize": {
    "$value": "vertical"
  }
}
