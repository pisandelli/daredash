{
  "$description": "Tokens for the Table component",
  "$type": "object",
  "width": {
    "$value": "100%"
  },
  "border-color": {
    "$value": "{color.secondary.100}"
  },
  "border-width": {
    "$value": "1px"
  },
  "border-radius": {
    "$value": "{border-radius.base}"
  },
  "border-collapse": {
    "$value": "collapse"
  },
  "header": {
    "$type": "object",
    "background-color": {
      "$value": "{color.secondary.50}"
    },
    "font-family": {
      "$value": "{font.base}"
    },
    "font-weight": {
      "$value": "{font.weight.bold}"
    },
    "text-transform": {
      "$value": "uppercase"
    },
    "text-align": {
      "$value": "left"
    },
    "padding": {
      "$value": "{space.md}"
    }
  },
  "cell": {
    "$type": "object",
    "padding": {
      "$value": "{space.md}"
    },
    "border-color": {
      "$value": "{table.border-color}"
    },
    "border-width": {
      "$value": "{table.border-width}"
    },
    "text-align": {
      "$value": "left"
    }
  },
  "row-striped": {
    "$type": "object",
    "background-color": {
      "$value": "{color.secondary.50}"
    }
  },
  "row-hover": {
    "$type": "object",
    "background-color": {
      "$value": "{color.secondary.100}"
    }
  },
  "empty-state": {
    "$type": "object",
    "color": {
      "$value": "{color.gray}"
    }
  },
  "error-state": {
    "$type": "object",
    "background-color": {
      "$value": "{color.danger.50}"
    },
    "color": {
      "$value": "{color.danger}"
    }
  }
}
