{
  "$description": "Tokens for the Table component",
  "$type": "object",
  "width": {
    "$value": "100%"
  },
  "border-color": {
    "$value": "{color.secondary.100}"
  },
  "border-width": {
    "$value": "1px"
  },
  "border-radius": {
    "$value": "{border-radius.base}"
  },
  "color": {
    "$value": "{color.text.default}"
  },
  "border-collapse": {
    "$value": "collapse"
  },
  "header": {
    "$type": "object",
    "background-color": {
      "$value": "{color.secondary.100}"
    },
    "color": {
      "$value": "{color.darker-gray}"
    },
    "font-family": {
      "$value": "{font.base}"
    },
    "font-size": {
      "$value": "{font-size.sm}"
    },
    "font-weight": {
      "$value": "{font-weight.bold}"
    },
    "text-transform": {
      "$value": "none"
    },
    "text-align": {
      "$value": "left"
    },
    "padding": {
      "$value": "{space.sm}"
    }
  },
  "cell": {
    "$type": "object",
    "font-size": {
      "$value": "{font-size.sm}"
    },
    "padding": {
      "$value": "{space.sm}"
    },
    "border-color": {
      "$value": "{table.border-color}"
    },
    "border-width": {
      "$value": "{table.border-width}"
    },
    "text-align": {
      "$value": "left"
    }
  },
  "row-striped": {
    "$type": "object",
    "background-color": {
      "$value": "{color.secondary.50}"
    }
  },
  "row-hover": {
    "$type": "object",
    "background-color": {
      "$value": "{color.primary.50}"
    }
  },
  "density": {
    "$type": "object",
    "large": {
      "$type": "object",
      "header": {
        "$type": "object",
        "font-size": {
          "$value": "{font-size.md}"
        }
      },
      "cell": {
        "$type": "object",
        "font-size": {
          "$value": "{font-size.md}"
        },
        "padding": {
          "$value": "{space.md}"
        }
      }
    },
    "comfortable": {
      "$type": "object",
      "header": {
        "$type": "object",
        "font-size": {
          "$value": "{table.header.font-size}"
        }
      },
      "cell": {
        "$type": "object",
        "font-size": {
          "$value": "{table.cell.font-size}"
        },
        "padding": {
          "$value": "{table.cell.padding}"
        }
      }
    },
    "compact": {
      "$type": "object",
      "header": {
        "$type": "object",
        "font-size": {
          "$value": "{font-size.xs}"
        }
      },
      "cell": {
        "$type": "object",
        "font-size": {
          "$value": "{font-size.xs}"
        },
        "padding": {
          "$value": "{space.xs}"
        }
      }
    }
  },
  "empty-state": {
    "$type": "object",
    "color": {
      "$value": "{color.gray}"
    }
  },
  "error-state": {
    "$type": "object",
    "background-color": {
      "$value": "{color.danger.50}"
    },
    "color": {
      "$value": "{color.danger}"
    }
  }
}
