{
  "$description": "Tokens for the Tabs component",
  "$type": "object",
  "list": {
    "border-color": {
      "$value": "{color.light-gray}"
    },
    "border-width": {
      "$value": "1px"
    },
    "gap": {
      "$value": "{space.sm}"
    },
    "padding": {
      "$value": "{space.sm}"
    }
  },
  "trigger": {
    "$description": "The individual 'button' (tab)",
    "$type": "object",
    "base-color": {
      "$value": "{color.primary.600}"
    },
    "padding": {
      "$value": "{tabs.trigger.size.regular.padding}"
    },
    "font-family": {
      "$value": "{font.system}"
    },
    "font-size": {
      "$value": "{tabs.trigger.size.regular.font-size}"
    },
    "font-weight": {
      "$value": "{font.weight.medium}"
    },
    "color": {
      "$value": "{color.gray}"
    },
    "bg": {
      "$value": "transparent"
    },
    "border-width": {
      "$value": "2px"
    },
    "border-radius": {
      "$value": "{border-radius.base}"
    },
    "icon-size": {
      "$value": "1.25rem"
    },
    "hover": {
      "$type": "object",
      "color": {
        "$value": "{color.dark-gray}"
      },
      "bg": {
        "$value": "{color.light-gray}"
      }
    },
    "active": {
      "$description": "For the [data-active] state",
      "$type": "object",
      "color": {
        "$value": "{color.primary}"
      },
      "border-color": {
        "$value": "{color.primary}"
      },
      "bg": {
        "$value": "transparent"
      }
    },
    "indicator": {
      "$type": "object",
      "color": {
        "$value": "{color.primary}"
      },
      "size": {
        "$value": "2px"
      }
    },
    "size": {
      "$description": "Sizing scale for the tabs",
      "small": {
        "padding": { "$value": "{space.xs} {space.sm}" },
        "font-size": { "$value": "{font-size.sm}" }
      },
      "regular": {
        "padding": { "$value": "{space.sm} {space.md}" },
        "font-size": { "$value": "{font-size.base}" }
      },
      "large": {
        "padding": { "$value": "{space.md}" },
        "font-size": { "$value": "{font-size.md}" }
      }
    }
  },
  "panel": {
    "$description": "The content panel",
    "$type": "object",
    "padding": {
      "$value": "{space.lg}"
    }
  }
}
