{
  "$description": "Tokens for the Pagination component",
  "$type": "object",
  "font-size": {
    "$value": "{font-size.sm}"
  },
  "color": {
    "$value": "{color.dark-gray}"
  },
  "bg": {
    "$value": "transparent"
  },
  "border-color": {
    "$value": "{color.light-gray}"
  },
  "color-hover": {
    "$value": "{color.primary}"
  },
