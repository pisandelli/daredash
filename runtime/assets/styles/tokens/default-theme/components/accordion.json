{
  "$description": "Tokens for the Accordion component (based on <details>)",
  "$type": "object",
  "border-width": {
    "$value": "1px"
  },
  "border-color": {
    "$value": "{color.light-gray}"
  },
  "border-radius": {
    "$value": "{border-radius.base}"
  },
  "accent-color": {
    "$value": "{color.primary.600}"
  },
  "header": {
    "$type": "object",
    "background-color": {
      "$value": "transparent"
    },
    "background-color-hover": {
      "$value": "{color.light-gray}"
    },
    "padding": {
      "$value": "{space.md}"
    },
    "font-family": {
      "$value": "{font.base}"
    },
    "font-size": {
      "$value": "{font-size.base}"
    },
    "font-weight": {
      "$value": "{font-weight.bold}"
    },
    "icon-size": {
      "$description": "Size of the icon (e.g., chevron)",
      "$value": "1em"
    },
    "chevron-size": {
      "$value": "1.125rem"
    },
    "gap": {
      "$value": "0.75rem"
    },
    "title-gap": {
      "$value": "0.625rem"
    }
  },
  "content": {
    "$type": "object",
    "padding": {
      "$value": "{accordion.header.padding}"
    },
    "background-color": {
      "$value": "#FFF"
    },
    "font-family": {
      "$value": "{font.system}"
    }
  },
  "primary": {
    "accent-color": {
      "$value": "{color.primary.600}"
    }
  },
  "success": {
    "accent-color": {
      "$value": "{color.success}"
    }
  },
  "warning": {
    "accent-color": {
      "$value": "{color.warning}"
    }
  },
  "danger": {
    "accent-color": {
      "$value": "{color.danger}"
    }
  },
  "info": {
    "accent-color": {
      "$value": "{color.info}"
    }
  }
}
