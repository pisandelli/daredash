{
  "$description": "Tokens for the Button component",
  "$type": "object",
  "base-color": {
    "$value": "{color.primary.600}"
  },
  "color": {
    "$value": "contrast-color({button.base-color})"
  },
  "border-radius": {
    "$value": "{border-radius.base}"
  },
  "font-family": {
    "$value": "{font.base}"
  },
  "font-weight": {
    "$value": "{font-weight.medium}"
  },
  "text-transform": {
    "$value": "none"
  },
  "sizes": {
    "tiny": {
      "height": {
        "$value": "1.75rem"
      },
      "padding": {
        "$value": "0.5rem"
      },
      "font-size": {
        "$value": "{font-size.xs}"
      },
      "icon-size": {
        "$value": "1rem"
      }
    },
    "small": {
      "height": {
        "$value": "2rem"
      },
      "padding": {
        "$value": "0.75rem"
      },
      "font-size": {
        "$value": "{font-size.sm}"
      },
      "icon-size": {
        "$value": "1.25rem"
      }
    },
    "regular": {
      "height": {
        "$value": "2.5rem"
      },
      "padding": {
        "$value": "1rem"
      },
      "font-size": {
        "$value": "{font-size.base}"
      },
      "icon-size": {
        "$value": "1.25rem"
      }
    },
    "large": {
      "height": {
        "$value": "3rem"
      },
      "padding": {
        "$value": "1.5rem"
      },
      "font-size": {
        "$value": "{font-size.lg}"
      },
      "icon-size": {
        "$value": "1.5rem"
      }
    },
    "xlarge": {
      "height": {
        "$value": "3.5rem"
      },
      "padding": {
        "$value": "2rem"
      },
      "font-size": {
        "$value": "{font-size.xl}"
      },
      "icon-size": {
        "$value": "1.75rem"
      }
    }
  },
  "semantic": {
    "inline": {
      "$value": "{space.lg}"
    },
    "block": {
      "$value": "{space.sm}"
    }
  },
  "icon": {
    "gap": {
      "$value": "{space.xs}"
    }
  },
  "primary": {
    "base-color": {
      "$value": "{color.primary.600}"
    },
    "color": {
      "$value": "contrast-color({button.primary.base-color})"
    }
  },
  "success": {
    "base-color": {
      "$value": "{color.success}"
    },
    "color": {
      "$value": "contrast-color({button.success.base-color})"
    }
  },
  "warning": {
    "base-color": {
      "$value": "{color.warning}"
    },
    "color": {
      "$value": "contrast-color({button.warning.base-color})"
    }
  },
  "danger": {
    "base-color": {
      "$value": "{color.danger}"
    },
    "color": {
      "$value": "contrast-color({button.danger.base-color})"
    }
  },
  "info": {
    "base-color": {
      "$value": "{color.info}"
    },
    "color": {
      "$value": "contrast-color({button.info.base-color})"
    }
  }
}
