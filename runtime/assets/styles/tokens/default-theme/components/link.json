{
  "$description": "Tokens for the Link component (for [data-link])",
  "$type": "object",
  "color": {
    "$value": "{color.primary}"
  },
  "text-decoration": {
    "$value": "underline"
  },
  "hover": {
    "$type": "object",
    "color": {
      "$value": "{color.accent}"
    }
  },
  "focus": {
    "$type": "object",
    "outline-color": {
      "$value": "{color.primary}"
    },
    "outline-width": {
      "$value": "2px"
    },
    "outline-offset": {
      "$value": "2px"
    }
  }
}
